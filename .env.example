# Oracle Autonomous Database credentials (OBLIGATORIO)
ORACLE_USER=admin
ORACLE_PASSWORD=poner_password_aqui

# Oracle connection string (TNS name from wallet/tnsnames.ora)
ORACLE_CONNECT=afemecdeportes_high

# MODO LOCAL (con Instant Client): ruta al Instant Client
# ORACLE_IC=C:\\oracle\\instantclient\\instantclient_23_0

# MODO NUBE (sin Instant Client): wallet en base64
# ORACLE_WALLET_TNS=contenido_base64_de_tnsnames.ora
# ORACLE_WALLET_PEM=contenido_base64_de_ewallet.pem
# ORACLE_WALLET_P12=contenido_base64_de_ewallet.p12
# ORACLE_WALLET_SSO=contenido_base64_de_cwallet.sso

# API server port (opcional, default 3046)
API_PORT=3046

# Static file server port (opcional, default 3045)
STATIC_PORT=3045
